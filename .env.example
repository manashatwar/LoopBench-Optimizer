# LoopBench Optimizer — environment template
# Copy this file to `.env` and fill in your key:
#     cp .env.example .env
#
# LoopBench talks to any OpenAI-compatible LLM endpoint. Pick ONE provider
# below and set the three variables. The API key variable is always named
# GEMINI_API_KEY regardless of which provider you use.

# ── Option A: Groq (fast, free tier) ──────────────────────────────────────────
GEMINI_API_KEY="gsk_your_groq_key_here"
LLM_API_BASE="https://api.groq.com/openai/v1"
LLM_MODEL="llama-3.3-70b-versatile"

# ── Option B: Google Gemini ───────────────────────────────────────────────────
# GEMINI_API_KEY="your_gemini_key_here"
# LLM_API_BASE="https://generativelanguage.googleapis.com/v1beta/openai/"
# LLM_MODEL="gemini-2.0-flash"

# ── Option C: OpenAI ──────────────────────────────────────────────────────────
# GEMINI_API_KEY="sk-your_openai_key_here"
# LLM_API_BASE="https://api.openai.com/v1"
# LLM_MODEL="gpt-4o-mini"

# ── Optional ──────────────────────────────────────────────────────────────────
# Needed only when optimizing a private GitHub repo via --target <url>
# GITHUB_TOKEN="ghp_your_token_here"
