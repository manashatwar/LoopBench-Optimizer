# ────────────────────────────────────────────────────────────
# LoopBench-Optimizer .gitignore
# ────────────────────────────────────────────────────────────

# Secrets — NEVER commit
.env
.env.*
secrets.yaml

# Virtual environments
.venv/
venv/
env/
ENV/

# Python artifacts
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
*.lock

# IDE
.idea/
.vscode/
*.swp
*.swo

# Generated output directories
openevolve_output*/
loopbench_output*/
optimizer_output*/
results/
demo_output*/
pr_sanity*/
*.log

# Example outputs (keep example code, not generated artifacts)
examples/*/output/
examples/lm_eval/prompts/system_message.txt
examples/lm_eval/prompts/evaluator_system_message.txt

# Test & coverage cache
.pytest_cache/
.coverage
htmlcov/
.hypothesis/tmp/
.hypothesis/unicode_data/

# Type checker & linter cache
.mypy_cache/
.ruff_cache/

# Repo context cache (runtime generated)
.cache/

# SQLite databases (runtime generated)
*.db
*.sqlite
*.sqlite3

# Stray directories from sandbox runs
C/

# macOS
.DS_Store

# Kiro IDE — specs, hooks, steering files (local tooling, not for repo)
.kiro/

# SR / misc
problems
